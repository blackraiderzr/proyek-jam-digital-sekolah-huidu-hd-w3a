<?xml version="1.0" encoding="UTF-8"?>
<HD2020MainConfig>
  <ProjectInfo>
    <ProjectName>Jam Digital Sekolah - Huidu HD-W3A</ProjectName>
    <School>SMKN 9 SURAKARTA</School>
    <Department>XI TJKT 3</Department>
    <Team>Kelompok 1</Team>
  </ProjectInfo>

  <Controller>
    <Model>HD-W3A</Model>
    <Software>HD2020</Software>
    <Communication>WiFi</Communication>
    <IPAddress>192.168.4.1</IPAddress>
    <Port>5005</Port>
  </Controller>

  <Display>
    <Width>128</Width>
    <Height>64</Height>
    <ColorType>RGB</ColorType>
    <Brightness day="80" night="45" />
    <RefreshRate>1920</RefreshRate>
  </Display>

  <TimeSettings>
    <Timezone>Asia/Jakarta</Timezone>
    <Format>24H</Format>
    <Sync>NTP</Sync>
    <NtpServer>id.pool.ntp.org</NtpServer>
    <ShowSeconds>true</ShowSeconds>
    <ShowDate>true</ShowDate>
    <DateFormat>dddd, dd MMMM yyyy</DateFormat>
  </TimeSettings>

  <TextLayers>
    <Layer id="1" name="Clock" x="0" y="0" width="128" height="32" font="Digital-7" size="28" color="#22C55E" align="center" />
    <Layer id="2" name="Date" x="0" y="34" width="128" height="14" font="Arial" size="9" color="#38BDF8" align="center" />
    <Layer id="3" name="SchoolInfo" x="0" y="50" width="128" height="14" font="Arial" size="8" color="#F59E0B" align="center" />
  </TextLayers>

  <Notes>
    <Note>File ini dapat dijadikan template awal setingan main proyek Huidu HD2020.</Note>
    <Note>Silakan sesuaikan parameter ukuran panel dengan hardware yang digunakan.</Note>
  </Notes>
</HD2020MainConfig>
